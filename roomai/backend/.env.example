ANTHROPIC_API_KEY=
# For Postgres: postgresql://user:pass@localhost:5432/roomai
# For local dev (default), SQLite is used if DATABASE_URL is unset:
DATABASE_URL=sqlite:///./roomai.db
JWT_SECRET=change-me-to-a-long-random-string
STORAGE_PATH=./storage/uploads
ENVIRONMENT=development
# Model used for vision analysis
ANTHROPIC_MODEL=claude-opus-4-8
